---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: siteConfig.name,
  email: siteConfig.email,
  description: 'Brand partnerships, recruitment and placement, and website services.'
};
---

<BaseLayout
  title="Home"
  description="S Solutions supports brands, partnerships, recruitment, placement, and website services."
  ogTitle="S Solutions"
  ogDescription="Brand partnerships, recruitment and placement, and web services."
  jsonLd={jsonLd}
>
  <Header current="home" />
  <main>
    <section class="hero" role="region" aria-labelledby="heroHeading">
      <div class="hero-wrapper">
        <div class="hero-content">
          <div class="hero-tag">Brand partnerships, recruitment, and web services</div>
          <h1 id="heroHeading">Practical business support for growth-focused teams.</h1>
          <p class="hero-subtitle">Placeholder tagline: replace with the preferred message from the client presentation when the PPT assets are supplied.</p>
          <div class="hero-buttons">
            <a href="#services" class="btn btn-primary btn-large">View Services</a>
            <a href={base + '/contact/'} class="btn btn-secondary btn-large">Get in Touch</a>
          </div>
        </div>
        <div class="hero-image-placeholder asset-placeholder">
          <div>
            <strong>Presentation image placeholder</strong>
            <span>Add logo, imagery, and copy from the attached PPT.</span>
          </div>
        </div>
      </div>
    </section>

    <section class="notice" role="region" aria-labelledby="assetNoticeHeading">
      <h2 id="assetNoticeHeading">Client Assets Needed</h2>
      <p>PPT attachments were not available in this workspace. Brand logo, exact colors, typography, presentation copy, partner logos, and downloadable presentation files need to be supplied by the client.</p>
    </section>

    <section id="services" class="features services-section" role="region" aria-labelledby="servicesHeading">
      <h2 id="servicesHeading">Services</h2>
      <p class="section-intro">S Solutions can be positioned around these three service areas until the presentation copy is available.</p>
      <div class="features-grid services-grid">
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">B</div>
          <h3>Brands & Partnerships</h3>
          <p>Support for brand collaborations, partners, tie-ups, vendors, and franchise opportunities.</p>
          <a href={base + '/partnerships/'} class="btn btn-small">Partnerships</a>
        </article>
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">R</div>
          <h3>Recruitment & Placement</h3>
          <p>Recruitment and placement support for call centres, HR teams, and hiring operations.</p>
          <a href={base + '/contact/'} class="btn btn-small">Discuss Hiring</a>
        </article>
        <article class="feature-card">
          <div class="feature-icon" aria-hidden="true">W</div>
          <h3>Web Services</h3>
          <p>Website builder, web builder, and website service support for businesses moving online.</p>
          <a href={base + '/contact/'} class="btn btn-small">Start a Website</a>
        </article>
      </div>
    </section>
  </main>
  <Footer />
</BaseLayout>
