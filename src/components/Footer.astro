---
import { siteConfig } from '../config/site';

const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<footer role="contentinfo">
  <div class="footer-content">
    <div class="footer-section">
      <h3>Quick Links</h3>
      <ul>
        <li><a href={base + '/'}>Home</a></li>
        <li><a href={base + '/#services'}>Services</a></li>
        <li><a href={base + '/partnerships/'}>Partnerships</a></li>
        <li><a href={base + '/presentations/'}>Presentations</a></li>
        <li><a href={base + '/contact/'}>Contact</a></li>
      </ul>
    </div>
    <div class="footer-section">
      <h3>Social</h3>
      <div class="social-links">
        {siteConfig.instagramUrl ? (
          <a href={siteConfig.instagramUrl} aria-label="Instagram" target="_blank" rel="noopener noreferrer">Instagram</a>
        ) : (
          <span class="placeholder-link">Instagram</span>
        )}
      </div>
    </div>
    <div class="footer-section">
      <h3>Contact</h3>
      <ul>
        <li><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
        <li>WhatsApp: add number</li>
      </ul>
    </div>
  </div>
  <div class="footer-bottom">
    <p>&copy; <span id="year">2026</span> {siteConfig.name}. All rights reserved.</p>
  </div>
</footer>
