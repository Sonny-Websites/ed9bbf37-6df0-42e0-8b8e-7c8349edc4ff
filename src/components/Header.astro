---
import { siteConfig } from '../config/site';

interface Props {
  current?: 'home' | 'services' | 'partnerships' | 'presentations' | 'contact' | 'thank-you';
}

const { current } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '') || '';
---

<header role="banner">
  <nav role="navigation" aria-label="Main navigation">
    <a href={base + '/'} class="logo" aria-label="S Solutions home">
      <span class="logo-mark" aria-hidden="true">S</span>
      <span>{siteConfig.name}</span>
    </a>
    <button class="hamburger" id="hamburgerMenu" aria-label="Toggle navigation menu" aria-expanded="false" aria-controls="navMenu">
      <span></span>
      <span></span>
      <span></span>
    </button>
    <ul id="navMenu" class="nav-menu">
      <li><a href={base + '/'} aria-current={current === 'home' ? 'page' : undefined}>Home</a></li>
      <li><a href={base + '/#services'} aria-current={current === 'services' ? 'page' : undefined}>Services</a></li>
      <li><a href={base + '/partnerships/'} aria-current={current === 'partnerships' ? 'page' : undefined}>Partnerships</a></li>
      <li><a href={base + '/presentations/'} aria-current={current === 'presentations' ? 'page' : undefined}>Presentations</a></li>
      <li><a href={base + '/contact/'} aria-current={current === 'contact' ? 'page' : undefined}>Contact</a></li>
      <li class="mobile-only"><a href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a></li>
      <li class="mobile-only"><a class="btn btn-header" href={base + '/contact/'}>Get in Touch</a></li>
    </ul>
    <div class="header-actions">
      <a class="header-email" href={`mailto:${siteConfig.email}`}>{siteConfig.email}</a>
      <a class="btn btn-header" href={base + '/contact/'}>Get in Touch</a>
    </div>
  </nav>
</header>
